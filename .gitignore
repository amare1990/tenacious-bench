# ----------------------
# Data (raw or large)
# ----------------------
# Ignore large / regenerable raw data
data/raw/crunchbase/*.json
data/raw/job_posts/*
data/raw/press/*
data/raw/tech_stack/*

# Ignore bulk processed outputs (keep selected manually)
data/processed/enrichment/*
!data/processed/enrichment/ramp/
!data/processed/enrichment/clay/
!data/processed/enrichment/retool/

data/processed/leads/*
!data/processed/leads/ramp.json
!data/processed/leads/clay.json
!data/processed/leads/retool.json

# Ignore logs
data/*.jsonl

# ----------------------
